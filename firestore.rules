rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /sharedBoards/{boardId}/meta/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /sharedBoards/{boardId}/entries/{entryId} {
      allow read, write: if request.auth != null;
    }
  }
}
